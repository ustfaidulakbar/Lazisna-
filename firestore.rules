rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global deny-by-default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function isSignedIn() { return request.auth != null; }

    // Validate user document
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.wa is string;
    }

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      
      // Users can create/update their own profile
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }
  }
}
